{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "api-dist",
    "rootDir": "api",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules"]
}